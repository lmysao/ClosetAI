# ---------- BANCO DE DADOS (SQLite local - desenvolvimento) ----------
# Caminho do arquivo SQLite. Por padrão, na pasta db/ do projeto.
DATABASE_URL="file:./dev.db"

# ---------- BANCO EM PRODUÇÃO (Supabase) ----------
# URL de conexão do Supabase PostgreSQL
# Formato: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
SUPABASE_DATABASE_URL="postgresql://postgres:[password]@zegztgviqzszpwbafyfv.supabase.co:5432/postgres"

# ---------- SUPABASE CLIENT (Frontend) ----------
# URL pública do Supabase
NEXT_PUBLIC_SUPABASE_URL="https://zegztgviqzszpwbafyfv.supabase.co"
# Chave anônima do Supabase (pública)
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publisha*****yA_aNCtQItc"

# ---------- SUPABASE SERVICE ROLE (Backend - opcional) ----------
# Chave de serviço do Supabase (para operações administrativas)
# SUPABASE_SERVICE_ROLE_KEY="sua_service_role_key"

# ---------- CREDENCIAIS DA IA - GEMINI (Visão) ----------
# API Key do Google Gemini para análise de imagens
GEMINI_API_KEY="sua_gemini_api_key"
# Modelo Gemini para visão (ex: gemini-2.5-flash, gemini-2.5-pro)
GEMINI_VISION_MODEL="gemini-2.5-flash"

# ---------- CREDENCIAIS DA IA - GROQ (Texto) ----------
# API Key do Groq para geração de texto
GROQ_API_KEY="sua_groq_api_key"
# Modelo Groq para texto (ex: llama-3.3-70b-versatile, mixtral-8x7b-32768)
GROQ_TEXT_MODEL="llama-3.3-70b-versatile"

# ---------- AMBIENTE ----------
NODE_ENV="development"
