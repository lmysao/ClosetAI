# ============================================================
# ClosetAI — Variáveis de Ambiente
# ============================================================

# ---------- BANCO DE DADOS (Supabase / PostgreSQL) ----------
# Pegue a connection string no painel do Supabase:
#   Project Settings → Database → Connection string → URI
# Formato: postgresql://postgres.[projeto]:[SENHA]@aws-0-[regiao].pooler.supabase.com:6543/postgres
#
# Use a connection POOLER (porta 6543) para apps serverless/web services.
# Use a connection DIRETA (porta 5432) só para migrations locais.
DATABASE_URL="postgresql://postgres:[SUA_SENHA]@db.[PROJETO].supabase.co:5432/postgres"

# Dica: para o Render, use a pooler (porta 6543) para evitar esgotar conexões:
# DATABASE_URL="postgresql://postgres.[PROJETO]:[SUA_SENHA]@aws-0-[regiao].pooler.supabase.com:6543/postgres"

# ---------- CREDENCIAIS DA IA ----------
# Configure conforme a documentação do z-ai-web-dev-sdk
# ZAI_API_KEY=sua_chave_aqui

# ---------- AMBIENTE ----------
NODE_ENV="development"
