# ============================================================
# ClosetAI — Variáveis de Ambiente
# ============================================================

# ---------- BANCO DE DADOS (SQLite local) ----------
# Caminho do arquivo SQLite. Por padrão, na pasta db/ do projeto.
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# ---------- BANCO EM PRODUÇÃO (Render + disco persistente) ----------
# No Render, o filesystem é efêmero. Use um Disk persistente e aponte para ele:
# 1. Adicione um Disk no serviço: Mount Path = /opt/data, Size = 1GB
# 2. Configure a variável no Render:
# DATABASE_URL="file:/opt/data/custom.db"

# ---------- CREDENCIAIS DA IA ----------
# Configure conforme a documentação do z-ai-web-dev-sdk
# ZAI_API_KEY=sua_chave_aqui

# ---------- AMBIENTE ----------
NODE_ENV="development"
